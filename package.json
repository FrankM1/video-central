      "depends": [
        "jquery",
        "underscore"
      ]
    }
  },
  "devDependencies": {
    "@lodder/grunt-postcss": "^3.1.1",
    "autoprefixer": "^10.5.0",
    "browserify": "^17.0.1",
    "browserify-shim": "^3.8.16",
    "cssnano": "^7.1.5",
    "eslint": "^9.27.0",
    "globals": "^17.5.0",
    "grunt": "^1.6.2",
    "grunt-browserify": "^6.0.0",
    "grunt-contrib-cssmin": "^5.0.0",
    "grunt-contrib-uglify": "^5.2.2",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-eslint": "^26.0.0",
    "grunt-sass": "^4.1.0",
    "grunt-wp-i18n": "^1.0.4",
    "jit-grunt": "^0.10.0",
    "postcss": "^8.5.3",
    "sass": "^1.99.0",
    "time-grunt": "^2.0.0"
  },
  "overrides": {
    "minimatch": "^3.1.2"
  },
  "dependencies": {}
